#!/usr/bin/env bash
set -euo pipefail

# Run SwiftLint on staged .swift files
STAGED_SWIFT=$(git diff --cached --name-only --diff-filter=ACM -- '*.swift')

if [ -z "$STAGED_SWIFT" ]; then
    exit 0
fi

if ! command -v swiftlint &> /dev/null; then
    echo "warning: SwiftLint not installed, skipping lint (brew install swiftlint)"
    exit 0
fi

echo "Running SwiftLint on staged files..."

# Auto-detect Xcode for SourceKit
if [ -z "${DEVELOPER_DIR:-}" ] && [ -d /Applications/Xcode.app ]; then
    export DEVELOPER_DIR=/Applications/Xcode.app/Contents/Developer
fi

LINT_FAILED=0
echo "$STAGED_SWIFT" | while IFS= read -r file; do
    if [ -f "$file" ]; then
        swiftlint lint --strict --quiet "$file" || LINT_FAILED=1
    fi
done

if [ "$LINT_FAILED" -ne 0 ]; then
    echo "SwiftLint found issues. Fix them before committing."
    exit 1
fi
